## Ignore Visual Studio temporary files, build results, and
## files generated by popular Visual Studio add-ons.
##
## Get latest from https://github.com/github/gitignore/blob/master/VisualStudio.gitignore

# User-specific files
*.rsuser
*.suo
*.user
*.userosscache
*.sln.docstates

# Build results
[Dd]ebug/
[Dd]ebugPublic/
[Rr]elease/
[Rr]eleases/
x64/
x86/
[Ww][Ii][Nn]32/
[Aa][Rr][Mm]/
[Aa][Rr][Mm]64/
bld/
[Bb]in/
[Oo]bj/
[Ll]og/
[Ll]ogs/

# Visual Studio cache/options
.vs/

# Visual Studio Code
.vscode/
*.code-workspace

# Rider
.idea/
*.sln.iml

# NuGet Packages
*.nupkg
*.snupkg
*.nuget.props
*.nuget.targets

# Local Environment files
.env
.env.local
.env.*.local

# User secrets
secrets.json
appsettings.local.json

# --- Additional .NET Refinement ---
# EF Core Logic
*.db
*.db-shm
*.db-wal

# Test results
[Tt]est[Rr]esult*/

# OS-specific files
.DS_Store
Thumbs.db

# Build artifacts
/publish/

# BenchmarkDotNet
/BenchmarkDotNet.Artifacts/